---
layout: null
permalink: /feed.json
---
[{% for post in site.posts limit:10 %}
  {
    "title": {{ post.title | jsonify }},
    "date": "{{ post.date | date: '%b %d, %Y' }}",
    "url": "https://blog.yougrowonline.in{{ post.url }}",
    "description": {{ post.description | default: post.excerpt | strip_html | truncatewords: 30 | jsonify }},
    "image": "{{ post.image | default: 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?w=400&q=80' }}",
    "categories": {{ post.categories | jsonify }}
  }{% unless forloop.last %},{% endunless %}
{% endfor %}]
